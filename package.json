{
  "name": "bitbucket-buddy",
  "type": "module",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "tsc -b && TARGET_BROWSER=chrome vite build",
    "build:firefox": "tsc -b && cross-env TARGET_BROWSER=firefox vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.5.0",
    "cross-env": "^7.0.3",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-zip-pack": "^1.2.4"
  }
}
